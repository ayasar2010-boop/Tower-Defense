{
  // ─── Editor Temelleri ───────────────────────────────────────────────────────
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [100],
  "editor.wordWrap": "off",
  "editor.renderWhitespace": "boundary",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",

  // ─── Clang-Format (C kodu formatlama) ───────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "ms-vscode.cpptools",
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.formatOnSave": true
  },
  "C_Cpp.clang_format_style": "{BasedOnStyle: LLVM, IndentWidth: 4, ColumnLimit: 100, AllowShortFunctionsOnASingleLine: None, BreakBeforeBraces: Attach}",
  "C_Cpp.clang_format_fallbackStyle": "LLVM",

  // ─── Clangd devre dışı (ms-vscode.cpptools kullanılıyor, çakışmayı önler) ──
  "clangd.enabled": false,

  // ─── IntelliSense ───────────────────────────────────────────────────────────
  "C_Cpp.intelliSenseEngine": "default",
  "C_Cpp.autocomplete": "default",
  "C_Cpp.errorSquiggles": "enabled",
  "C_Cpp.default.compilerPath": "C:/msys64/mingw64/bin/gcc.exe",
  "C_Cpp.default.cStandard": "c99",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/src",
    "C:/msys64/mingw64/include"
  ],

  // ─── Dosya Hariç Tutma (Build / Cache dosyaları) ────────────────────────────
  "files.exclude": {
    "**/.git": true,
    "release/": true,
    "**/*.o": true,
    "**/*.d": true,
    "**/__pycache__/": true,
    "**/*.meta": true,
    "**/*.import": true,
    "build_log.txt": true,
    "build_err.txt": true,
    "build_out.txt": true,
    "out.txt": true,
    "err.txt": true,
    "build.bat": true,
    "libraylib.dll": true,
    "glfw3.dll": true,
    "game.exe": true
  },
  "search.exclude": {
    "release/": true,
    "**/*.o": true
  },

  // ─── Dosya İlişkilendirme ────────────────────────────────────────────────────
  "files.associations": {
    "*.h": "c",
    "*.c": "c",
    "*.glsl": "glsl",
    "*.vert": "glsl",
    "*.frag": "glsl",
    "*.vs": "glsl",
    "*.fs": "glsl"
  },

  // ─── Terminal ────────────────────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.env.windows": {
    "PATH": "C:/msys64/usr/bin;C:/msys64/mingw64/bin;${env:PATH}"
  },

  // ─── Makefile Tools ──────────────────────────────────────────────────────────
  "makefile.makefilePath": "${workspaceFolder}/Makefile",
  "makefile.buildLog": "${workspaceFolder}/build_log.txt",

  // ─── TODO Tree (Görev takibi) ────────────────────────────────────────────────
  "todo-tree.general.tags": ["TODO", "FIXME", "HACK", "BUG", "NOTE", "XXX"],
  "todo-tree.highlights.defaultHighlight": {
    "type": "text"
  }
}
