{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: game.exe (GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/release/game.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/release",
      "environment": [
        {
          "name": "PATH",
          "value": "C:/msys64/mingw64/bin;${env:PATH}"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
      "preLaunchTask": "Build: make",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for GDB",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set disassembly flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ],
      "logging": {
        "moduleLoad": false,
        "trace": false
      }
    },
    {
      "name": "Run: game.exe (no debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/release/game.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/release",
      "environment": [
        {
          "name": "PATH",
          "value": "C:/msys64/mingw64/bin;${env:PATH}"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
      "preLaunchTask": "Build: make"
    }
  ]
}
